{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "kntnt-photo-drop/drop-zone",
	"title": "Photo Drop Zone",
	"category": "kntnt",
	"description": "A capability-gated front-end bulk uploader bound to one collection; images are optimised in the browser before upload.",
	"keywords": [ "photo", "upload", "drop zone", "collection" ],
	"textdomain": "kntnt-photo-drop",
	"editorScript": "file:./index.tsx",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"anchor": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	}
}
